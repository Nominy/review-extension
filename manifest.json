{
  "manifest_version": 3,
  "name": "Babel Review Action Interceptor (Dev)",
  "version": "0.3.0",
  "description": "Review assistant: intercepts review APIs and uses Bun backend (local or remote) for metrics, prompts, interactive sessions, and LLM feedback.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://dashboard.babel.audio/*",
    "https://reviewgen.ovh/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.babel.audio/*"
      ],
      "js": [
        "dist/content/entry.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/content/page-bridge.js",
        "session.html",
        "dist/session/entry.js",
        "dist/session/entry.js.map"
      ],
      "matches": [
        "https://dashboard.babel.audio/*"
      ]
    }
  ]
}
