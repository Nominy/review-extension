{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "types": ["chrome"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
